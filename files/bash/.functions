# GitHub CLI wrapper to ensure GH_TOKEN is set from GITHUB_PERSONAL_TOKEN
gh() { GH_TOKEN="$GITHUB_PERSONAL_TOKEN" command gh "$@"; }

# Clipboard helper: copy stdin to terminal clipboard via OSC 52 sequence
sclip() {
  if [ -n "$TMUX" ]; then
    # Load stdin into tmux buffer and let tmux export it via set-clipboard external
    tmux load-buffer - \; run-shell "tmux save-buffer - | true" >/dev/null
  else
    local data
    data="$(base64 | tr -d '\r\n')"
    printf '\033]52;c;%s\a' "$data" > /dev/tty
  fi
}

# List all dependencies of a given Python module. This requires python -m module syntax, a la Chain.message.messaage
deps() {
    if [ -z "$1" ]; then
        echo "Usage: deps <module_name>"
        return 1
    fi
    python -v -m "$1" 2>&1 | grep "^import" | sort -u
}
# Simple directory navigation helpers
## cdin: change into the first subdirectory in the current directory
cdin() {
    shopt -s dotglob nullglob   # include hidden dirs; avoid literal "*/" if none
    local dirs=(*/)
    shopt -u dotglob            # revert so it doesn't affect the rest of the shell
    if [ ${#dirs[@]} -eq 0 ] || [ ! -d "${dirs[0]}" ]; then
        echo "No directories found"
        return 1
    fi
    cd "${dirs[0]}" || return
}

## (Internal helper) Get the git repository root path
## Prints path to stdout on success.
## Prints error to stderr and returns 1 on failure.
_get_git_root() {
    local root
    root=$(git rev-parse --show-toplevel 2>/dev/null) || {
        echo "Not inside a git repository." >&2
        return 1
    }
    echo "$root"
}

## Change directory to the root of the current git repository
cdroot() {
    local root
    root=$(_get_git_root) || return 1
    cd "$root" || return
}

## Change directory to the first package directory inside src/
cdpkg() {
    local root
    root=$(_get_git_root) || return 1

    local pkg_dir
    pkg_dir=$(find "$root/src" -mindepth 1 -maxdepth 1 -type d | head -n 1)

    if [[ -z "$pkg_dir" ]]; then
        echo "No directory found in src/" >&2
        return 1
    fi

    cd "$pkg_dir" || return
}

## Change directory to the tests/ directory at the repo root
cdtests() {
    local root
    root=$(_get_git_root) || return 1

    local test_dir="$root/tests"

    if [[ ! -d "$test_dir" ]]; then
        echo "No tests/ directory found at $root" >&2
        return 1
    fi

    cd "$test_dir" || return
}
## Change directory to the dev/ directory at the repo root
cddev() {
    local root
    root=$(_get_git_root) || return 1

    local dev_dir="$root/dev"

    if [[ ! -d "$dev_dir" ]]; then
        echo "No dev/ directory found at $root" >&2
        return 1
    fi

    cd "$dev_dir" || return
}
## Change directory to the docs/ directory at the repo root
cddocs() {
    local root
    root=$(_get_git_root) || return 1

    local docs_dir="$root/docs"

    if [[ ! -d "$docs_dir" ]]; then
        echo "No docs/ directory found at $root" >&2
        return 1
    fi

    cd "$docs_dir" || return
}
## Change directory to the evals/ directory at the repo root
cdevals() {
    local root
    root=$(_get_git_root) || return 1

    local evals_dir="$root/evals"

    if [[ ! -d "$evals_dir" ]]; then
	echo "No evals/ directory found at $root" >&2
	return 1
    fi

    cd "$evals_dir" || return
}

# Create a standard .gitignore file for Python projects
giti() {
    cat > .gitignore <<'EOF'
# Universal
__pycache__/
.pytest_cache/
.mypy_cache/
*.py[cod]
*$py.class
*.egg-info/
*.db
.env
.DS_Store
.python-version
*.log
*.sqlite3
.venv
uv.lock
EOF
    echo ".gitignore created in $(pwd)"
}

# Create .envrc file with project-aware paths and venv activation
envrc() {
    # Using 'EOF' (in quotes) prevents the shell from expanding
    # variables like $PROJECT_ROOT or running $(git...) *now*.
    # It writes the literal string to the file.
    cat << 'EOF' > .envrc
# .envrc

# --- Project Path Exports ---
export PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)

if [[ -z "$PROJECT_ROOT" ]]; then
  echo "direnv: error: could not find git root." >&2
  exit 1
fi

export DEV="$PROJECT_ROOT/dev"
export DOCS="$PROJECT_ROOT/docs"
export TESTS="$PROJECT_ROOT/tests"

MAIN_PKG_DIR=$(find "$PROJECT_ROOT/src" -mindepth 1 -maxdepth 1 -type d | head -n 1)
if [[ -d "$MAIN_PKG_DIR" ]]; then
    export PACK="$MAIN_PKG_DIR"
fi

# --- Virtual Env Activation ---
deactivate 2>/dev/null || true
source .venv/bin/activate
EOF

    echo "Created .envrc. Run 'direnv allow' to activate."
}

# pypr <pkg>
# Generate/patch a pyproject.toml for Hatchling + src layout with py.typed support.
# Can be used standalone or called from mkpyproj.
pypr() {
  if [ -z "${1:-}" ]; then
    echo "Usage: pypr <package_name>" >&2
    return 1
  fi
  local pkg="$1"
  
  if [ ! -f pyproject.toml ]; then
    cat > pyproject.toml <<EOF
[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "$pkg"
version = "0.1.0"
EOF
    echo "✓ created pyproject.toml"
  fi
  
  # Prepend [build-system] if missing
  if ! grep -q '^\[build-system\]' pyproject.toml; then
    local _tmp
    _tmp="$(mktemp)"
    cat >"$_tmp" <<'EOF'
[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
EOF
    cat pyproject.toml >>"$_tmp"
    mv "$_tmp" pyproject.toml
    echo "✓ added [build-system] hatchling"
  else
    echo "• [build-system] exists"
  fi
  
  # Ensure [project].name = "<pkg>"
  if grep -q '^\[project\]' pyproject.toml; then
    if grep -q '^name\s*=' pyproject.toml; then
      sed -i.bak -E "0,/^name\s*=.*/s//name = \"$pkg\"/" pyproject.toml && rm -f pyproject.toml.bak
      echo "✓ set project.name = \"$pkg\""
    else
      awk -v pkg="$pkg" '
        {print}
        /^\[project\]$/ && !added {print "name = \"" pkg "\""; added=1}
      ' pyproject.toml > pyproject.toml.tmp && mv pyproject.toml.tmp pyproject.toml
      echo "✓ inserted project.name = \"$pkg\""
    fi
  else
    cat >> pyproject.toml <<EOF
[project]
name = "$pkg"
version = "0.1.0"
EOF
    echo "✓ created [project] with name/version"
  fi
  
  # Add/update wheel target for src layout
  if grep -q '^\[tool\.hatch\.build\.targets\.wheel\]' pyproject.toml; then
    # Update packages path
    awk -v pkg="$pkg" '
      BEGIN{inwheel=0}
      /^\[tool\.hatch\.build\.targets\.wheel\]/{inwheel=1}
      /^\[/{if($0 !~ /\[tool\.hatch\.build\.targets\.wheel\]/) inwheel=0}
      {
        if(inwheel && $0 ~ /^packages\s*=/){
          print "packages = [\"src/" pkg "\"]"; next
        }
        print
      }
    ' pyproject.toml > pyproject.toml.tmp && mv pyproject.toml.tmp pyproject.toml
    # Ensure sources=["src"]
    awk '
      BEGIN{inwheel=0; has=0}
      /^\[tool\.hatch\.build\.targets\.wheel\]/{inwheel=1}
      /^\[/{if($0 !~ /\[tool\.hatch\.build\.targets\.wheel\]/) inwheel=0}
      { if(inwheel && $0 ~ /^sources\s*=\s*\["src"\]/) has=1; print > "pyproject.toml.tmp" }
      END{ if(!has){ print "sources = [\"src\"]" >> "pyproject.toml.tmp" } }
    ' pyproject.toml; mv pyproject.toml.tmp pyproject.toml
  else
    cat >> pyproject.toml <<EOF
[tool.hatch.build.targets.wheel]
packages = ["src/$pkg"]
sources = ["src"]
EOF
  fi
  
  # Ensure py.typed is included in wheel (append or create include=)
  awk -v pkg="$pkg" '
    BEGIN{in=0; has=0}
    /^\[tool\.hatch\.build\.targets\.wheel\]/{in=1}
    /^\[/{if($0 !~ /\[tool\.hatch\.build\.targets\.wheel\]/) in=0}
    {
      if(in && $0 ~ /^include\s*=\s*\[/){inc=1}
      if(in && inc && $0 ~ /]/){inc=0}
      if(in && $0 ~ /src\/[^"]*\/py\.typed/){has=1}
      print > "pyproject.toml.tmp"
    }
    END{
      if(!has){
        print "py.typed not found in wheel include -> adding" > "/dev/stderr"
        print "include = [\"src/" pkg "/py.typed\"]" >> "pyproject.toml.tmp"
      }
    }
  ' pyproject.toml 2>/dev/null; mv pyproject.toml.tmp pyproject.toml
  
  # Ensure py.typed is included in sdist target too
  if ! grep -q '^\[tool\.hatch\.build\.targets\.sdist\]' pyproject.toml; then
    cat >> pyproject.toml <<EOF
[tool.hatch.build.targets.sdist]
include = ["src/$pkg/py.typed"]
EOF
  else
    awk -v pkg="$pkg" '
      BEGIN{ins=0; has=0}
      /^\[tool\.hatch\.build\.targets\.sdist\]/{ins=1}
      /^\[/{if($0 !~ /\[tool\.hatch\.build\.targets\.sdist\]/) ins=0}
      {
        if(ins && $0 ~ /src\/[^"]*\/py\.typed/){has=1}
        print > "pyproject.toml.tmp"
      }
      END{
        if(!has){
          print "include = [\"src/" pkg "/py.typed\"]" >> "pyproject.toml.tmp"
        }
      }
    ' pyproject.toml; mv pyproject.toml.tmp pyproject.toml
  fi
  
  echo "✓ configured hatch wheel/sdist targets (src/$pkg, py.typed)"
}
# mkpyproj <pkg>
# Assumes you're ALREADY in the new project root directory.
# Uses your existing helpers: giti (writes .gitignore) and envrc (creates .envrc).
mkpyproj() {
  if [ -z "${1:-}" ]; then
    echo "Usage: mkpyproj <package_name>" >&2
    return 1
  fi
  local pkg="$1"
  command -v uv >/dev/null 2>&1 || { echo "uv not found on PATH"; return 1; }
  command -v git >/dev/null 2>&1 || { echo "git not found on PATH"; return 1; }
  # 1) git + uv init (idempotent)
  [ -d .git ] || { git init >/dev/null && echo "✓ git init"; }
  if [ ! -f pyproject.toml ]; then
    uv init >/dev/null && echo "✓ uv init"
  else
    echo "• pyproject.toml exists (skip uv init)"
  fi
  # 2) remove uv's default main.py (if present)
  [ ! -f main.py ] || { rm -f main.py && echo "✓ removed main.py"; }
  # 3) src/<pkg> skeleton (+ py.typed)
  mkdir -p "src/$pkg"
  [ -f "src/$pkg/__init__.py" ] || printf "__all__ = []\n" > "src/$pkg/__init__.py"
  if [ ! -f "src/$pkg/__main__.py" ]; then
    cat > "src/$pkg/__main__.py" <<EOF
def main() -> None:
    print("hello from $pkg")
if __name__ == "__main__":
    main()
EOF
  fi
  # PEP 561 marker
  [ -f "src/$pkg/py.typed" ] || : > "src/$pkg/py.typed"
  echo "✓ created src/$pkg/ (with py.typed)"
  # 4) tests skeleton
  mkdir -p tests
  if [ ! -f tests/test_basic.py ]; then
    cat > tests/test_basic.py <<'EOF'
def test_sanity():
    assert True
EOF
    echo "✓ created tests/test_basic.py"
  else
    echo "• tests/test_basic.py exists"
  fi
  # 5) venv
  [ -d .venv ] || { uv venv >/dev/null && echo "✓ uv venv"; }
  # 6) .envrc via your helper
  if [ -f .envrc ]; then
    echo "• .envrc exists"
  else
    if command -v envrc >/dev/null 2>&1; then
      envrc && echo "✓ created .envrc via envrc"
    else
      echo "• envrc helper not found (skipping .envrc)"
    fi
  fi
  # 7) direnv allow (idempotent)
  direnv allow
  echo "✓ direnv allow"
  # 8) .gitignore via your giti helper
  if [ -f .gitignore ]; then
    echo "• .gitignore exists"
  else
    if typeset -f giti >/dev/null 2>&1; then
      giti && echo "✓ wrote .gitignore"
    else
      echo "• giti function not found (skipping .gitignore)"
    fi
  fi
  # 9) Patch pyproject.toml using pypr
  pypr "$pkg"
  echo "✅ Done at $(pwd)"
  uv sync --editable
  echo "✓ uv sync --editable"
  echo "Project setup complete. Start coding in src/$pkg and run tests with 'pytest'."
}
#
# Source custom functions if the file exists (for machine-specific aliases / overrides)
if [ -f ~/.custom_functions ]; then
    source ~/.custom_functions
fi

# generate password/username from an email alias (generated by SimpleLogin for a specific service)
pass_alias() {
    local alias="$1"

    if [[ -z "$alias" ]]; then
        echo "Usage: pass_alias_insert <email-alias>"
        return 1
    fi

    # Extract service name (everything before first dot)
    local service="${alias%%.*}"

    if [[ -z "$service" ]]; then
        echo "Error: could not determine service name from alias"
        return 1
    fi

    local pass_path="alias/$service"

    # Generate password
    local password
    if ! password="$(passwords)"; then
        echo "Error: password generation failed"
        return 1
    fi

    if [[ -z "$password" ]]; then
        echo "Error: password generator returned empty result"
        return 1
    fi

    # Generate username
    local username
    if ! username="$(usernames)"; then
        echo "Error: username generation failed"
        return 1
    fi

    if [[ -z "$username" ]]; then
        echo "Error: username generator returned empty result"
        return 1
    fi

    # Insert / overwrite multiline entry
    printf "%s\n%s\n%s\n" \
        "$password" \
        "$alias" \
        "$username" | \
        pass insert --force --multiline "$pass_path" >/dev/null

    echo "Updated pass entry:"
    echo "  Path:     $pass_path"
    echo "  Email:    $alias"
    echo "  Username: $username"
}

# Directory history tracking and quick navigation
## Track last 10 dirs
DHISTFILE="$HOME/.dir_history"
DHISTSIZE=10

## Hook into cd
_track_dir() {
    local previous="$OLDPWD"
    [ -z "$previous" ] && return
    [ -f "$DHISTFILE" ] || touch "$DHISTFILE"

    grep -vxF "$previous" "$DHISTFILE" > "$DHISTFILE.tmp"
    { echo "$previous"; cat "$DHISTFILE.tmp"; } | head -n "$DHISTSIZE" > "$DHISTFILE.tmp2"
    mv "$DHISTFILE.tmp2" "$DHISTFILE"
    rm -f "$DHISTFILE.tmp"
}

## Override cd to track history
cd() {
    builtin cd "$@" && _track_dir
}

## Jump functions - z1 is line 1 (most recent previous), z2 is line 2, etc.
z1() { builtin cd "$(sed -n '1p' "$DHISTFILE")" && _track_dir; }
z2() { builtin cd "$(sed -n '2p' "$DHISTFILE")" && _track_dir; }
z3() { builtin cd "$(sed -n '3p' "$DHISTFILE")" && _track_dir; }
z4() { builtin cd "$(sed -n '4p' "$DHISTFILE")" && _track_dir; }
z5() { builtin cd "$(sed -n '5p' "$DHISTFILE")" && _track_dir; }
z6() { builtin cd "$(sed -n '6p' "$DHISTFILE")" && _track_dir; }
z7() { builtin cd "$(sed -n '7p' "$DHISTFILE")" && _track_dir; }
z8() { builtin cd "$(sed -n '8p' "$DHISTFILE")" && _track_dir; }
z9() { builtin cd "$(sed -n '9p' "$DHISTFILE")" && _track_dir; }

## List history
zh() {
    [ -f "$DHISTFILE" ] && cat -n "$DHISTFILE"
}
